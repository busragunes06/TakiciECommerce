@model Web.ViewModels.Home.ContactMessageVm
@{
    ViewData["Title"] = "İletişim";
}

<div class="row align-items-center justify-content-center fade-in py-5" style="min-height: 60vh;">
    <div class="col-md-5 col-lg-5 mb-5 mb-lg-0 slide-up">
        <h2 class="brand-font display-5 mb-4 text-dark">Bize Ulaşın</h2>
        <p class="text-muted mb-4 pe-lg-5" style="line-height: 1.8;">Müşteri memnuniyeti bizim için en önemli değerdir. Bir tasarımımız hakkında bilgi almak veya sipariş durumunuzu öğrenmek için aşağıdaki formu doldurabilir ya da doğrudan bizimle iletişime geçebilirsiniz.</p>
        
        <div class="d-flex align-items-center mb-4">
            <div class="bg-white rounded-circle d-flex align-items-center justify-content-center shadow-sm text-primary me-3 flex-shrink-0" style="width: 50px; height: 50px;">
                <i class="fa-solid fa-location-dot"></i>
            </div>
            <div>
                <h5 class="mb-1 fw-semibold text-dark">Mağaza</h5>
                <p class="text-muted small mb-0">Nişantaşı Mah. Takıcılar Sk. No: 12 Şişli / İstanbul</p>
            </div>
        </div>
        
        <div class="d-flex align-items-center mb-4">
            <div class="bg-white rounded-circle d-flex align-items-center justify-content-center shadow-sm text-primary me-3 flex-shrink-0" style="width: 50px; height: 50px;">
                <i class="fa-solid fa-phone"></i>
            </div>
            <div>
                <h5 class="mb-1 fw-semibold text-dark">Telefon</h5>
                <p class="text-muted small mb-0">+90 (212) 555 44 33</p>
            </div>
        </div>

        <div class="d-flex align-items-center mb-4">
            <div class="bg-white rounded-circle d-flex align-items-center justify-content-center shadow-sm text-primary me-3 flex-shrink-0" style="width: 50px; height: 50px;">
                <i class="fa-regular fa-envelope"></i>
            </div>
            <div>
                <h5 class="mb-1 fw-semibold text-dark">E-Posta</h5>
                <p class="text-muted small mb-0">iletisim@takici.com.tr</p>
            </div>
        </div>
    </div>
    
    <div class="col-md-7 col-lg-5 slide-up" style="animation-delay: 0.2s;">
        <div class="glass-box p-4 p-md-5">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">
                    <i class="fa-solid fa-circle-check me-2"></i> @TempData["SuccessMessage"]
                </div>
            }

            <form asp-controller="Home" asp-action="Contact" method="post">
                @Html.AntiForgeryToken()
                <div class="row g-3">
                    <div class="col-sm-6">
                        <label asp-for="Name" class="form-label text-muted small text-uppercase letter-spacing-1">Adınız</label>
                        <input asp-for="Name" type="text" class="form-control" placeholder="Ad Soyad" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="col-sm-6">
                        <label asp-for="Email" class="form-label text-muted small text-uppercase letter-spacing-1">E-Posta</label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="ornek@mail.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Subject" class="form-label text-muted small text-uppercase letter-spacing-1">Konu</label>
                        <input asp-for="Subject" type="text" class="form-control" placeholder="Mesajınızın konusu" />
                        <span asp-validation-for="Subject" class="text-danger small"></span>
                    </div>
                    <div class="col-12 mb-3">
                        <label asp-for="Body" class="form-label text-muted small text-uppercase letter-spacing-1">Mesajınız</label>
                        <textarea asp-for="Body" class="form-control" rows="4" placeholder="Size nasıl yardımcı olabiliriz?"></textarea>
                        <span asp-validation-for="Body" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-medium">
                            <i class="fa-regular fa-paper-plane me-2"></i> Gönder
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
