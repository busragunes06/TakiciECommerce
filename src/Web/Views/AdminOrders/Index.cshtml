@model IEnumerable<Web.Models.Order>
@{
    ViewData["Title"] = "Siparişler";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2">Siparişler</h1>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-striped align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Tarih</th>
                        <th>Sipariş No</th>
                        <th>Kullanıcı (ID)</th>
                        <th>Toplam Tutar</th>
                        <th>Durum</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        <tr>
                            <td>@item.CreatedAtUtc.AddHours(3).ToString("dd.MM.yyyy HH:mm")</td>
                            <td><span class="text-muted small">#@item.Id.ToString().Substring(0, 8)</span></td>
                            <td title="@item.UserId">@item.UserId.Substring(0, Math.Min(item.UserId.Length, 8))...</td>
                            <td class="fw-bold">@item.TotalAmount.ToString("C")</td>
                            <td>
                                @if (item.Status == "Hazirlaniyor")
                                {
                                    <span class="badge bg-warning text-dark">Hazırlanıyor</span>
                                }
                                else if (item.Status == "Kargolandi")
                                {
                                    <span class="badge bg-info text-dark">Kargolandı</span>
                                }
                                else if (item.Status == "Teslim Edildi")
                                {
                                    <span class="badge bg-success">Teslim Edildi</span>
                                }
                                else if (item.Status == "Iptal Edildi")
                                {
                                    <span class="badge bg-danger">İptal Edildi</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@item.Status</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary"><i class="fa-solid fa-eye me-1"></i> Detay</a>
                            </td>
                        </tr>
                    }
                    @if(!Model.Any()) {
                        <tr><td colspan="6" class="text-center py-4 text-muted">Henüz sipariş bulunmamaktadır.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
