@model IEnumerable<Web.Models.Category>
@{
    ViewData["Title"] = "Kategoriler";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2">Kategoriler</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Create" class="btn btn-sm btn-primary">
            <i class="fa-solid fa-plus me-1"></i> Yeni Kategori Ekle
        </a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-striped align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Tarih</th>
                        <th>Kategori Adı</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        <tr>
                            <td>@item.CreatedAtUtc.AddHours(3).ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="fw-bold">@item.Name</td>

                            <td class="text-end">
                                <div class="btn-group">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary"><i class="fa-solid fa-pen"></i></a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                    @if(!Model.Any()) {
                        <tr><td colspan="3" class="text-center py-4 text-muted">Henüz kategori eklenmemiş.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>