@model Web.ViewModels.Orders.OrderDetailsVm

@{
    ViewData["Title"] = "Sipariş Detayı";
}

<div class="mb-3">
    <a class="text-decoration-none" asp-controller="Orders" asp-action="Index">← Siparişlerim</a>
</div>

<div class="d-flex align-items-start justify-content-between flex-wrap gap-2 mb-3">
    <div>
        <h2 class="mb-1">@ViewData["Title"]</h2>
        <div class="text-muted small">Sipariş No: @Model.Id</div>
        <div class="text-muted small">Tarih: @Model.CreatedAtUtc.ToLocalTime().ToString("f")</div>
    </div>
    <div>
        <span class="badge text-bg-light border mb-2 d-block">@Model.Status</span>
        <div class="text-end text-muted small"><i class="fa-solid fa-wallet"></i> @Model.PaymentMethod</div>
    </div>
</div>

<div class="card mb-4 border-0 bg-light">
    <div class="card-body">
        <h6 class="card-title fw-bold">Teslimat Bilgileri</h6>
        <p class="mb-1 small"><strong>Alıcı:</strong> @Model.ContactName (@Model.PhoneNumber)</p>
        <p class="mb-0 small"><strong>Adres:</strong> @Model.ShippingAddress <br> <strong>Şehir:</strong> @Model.City</p>
    </div>
</div>

<div class="table-responsive mb-3">
    <table class="table align-middle">
        <thead>
        <tr>
            <th>Ürün</th>
            <th class="text-end">Birim</th>
            <th class="text-end">Adet</th>
            <th class="text-end">Tutar</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.ProductName</td>
                <td class="text-end">@item.UnitPrice.ToString("C")</td>
                <td class="text-end">@item.Quantity</td>
                <td class="text-end">@item.LineTotal.ToString("C")</td>
            </tr>
        }
        </tbody>
        <tfoot>
        <tr>
            <th colspan="3" class="text-end">Toplam</th>
            <th class="text-end">@Model.TotalAmount.ToString("C")</th>
        </tr>
        </tfoot>
    </table>
</div>

