@model IEnumerable<Web.Models.Product>
@{
    ViewData["Title"] = "Ürünler";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2">Ürünler</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Create" class="btn btn-sm btn-primary">
            <i class="fa-solid fa-plus me-1"></i> Yeni Ürün Ekle
        </a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-striped align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th width="80">Görsel</th>
                        <th>Ürün Adı</th>
                        <th>Kategori</th>
                        <th>Fiyat</th>
                        <th>Stok</th>
                        <th>Durum</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        <tr>
                            <td>
                                @if(!string.IsNullOrEmpty(item.ImageUrl)) {
                                    <img src="@item.ImageUrl" alt="@item.Name" class="img-thumbnail" style="width: 50px; height: 50px; object-fit: cover;" />
                                } else {
                                    <div class="bg-light text-center text-muted d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                        <i class="fa-solid fa-image"></i>
                                    </div>
                                }
                            </td>
                            <td class="fw-bold">@item.Name</td>
                            <td>@(item.Category?.Name ?? "-")</td>
                            <td>@item.Price.ToString("C")</td>
                            <td>
                                @if(item.StockQuantity == 0) {
                                    <span class="badge bg-danger">Tükendi</span>
                                } else if(item.StockQuantity < 5) {
                                    <span class="badge bg-warning text-dark">Son @item.StockQuantity Ürün</span>
                                } else {
                                    <span class="text-success fw-bold">@item.StockQuantity</span>
                                }
                            </td>
                            <td>
                                @if(item.IsActive) {
                                    <span class="badge bg-success">Aktif</span>
                                } else {
                                    <span class="badge bg-secondary">Pasif</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="btn-group">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary"><i class="fa-solid fa-pen"></i></a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                    @if(!Model.Any()) {
                        <tr><td colspan="7" class="text-center py-4 text-muted">Henüz ürün eklenmemiş.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
