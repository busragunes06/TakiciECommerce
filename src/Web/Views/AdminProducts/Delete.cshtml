@model Web.Models.Product
@{
    ViewData["Title"] = "Ürün Sil";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2 text-danger">Ürün Sil</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="fa-solid fa-arrow-left me-1"></i> Listeye Dön
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="alert alert-danger shadow-sm border-0">
            <h4 class="alert-heading"><i class="fa-solid fa-triangle-exclamation me-2"></i>Uyarı!</h4>
            <p><strong>@Model.Name</strong> isimli ürünü silmek üzeresiniz. Bu işlem geri alınamaz.</p>
            <hr>
            
            <div class="row mb-4 bg-white p-3 rounded text-dark">
                <div class="col-md-3">
                    @if(!string.IsNullOrEmpty(Model.ImageUrl)) {
                        <img src="@Model.ImageUrl" class="img-fluid rounded" alt="@Model.Name" />
                    } else {
                        <div class="bg-light text-center text-muted d-flex align-items-center justify-content-center w-100 h-100 rounded" style="min-height: 100px;">
                            <i class="fa-solid fa-image fa-2x"></i>
                        </div>
                    }
                </div>
                <div class="col-md-9">
                    <p class="mb-1"><strong>Kategori:</strong> @(Model.Category?.Name ?? "-")</p>
                    <p class="mb-1"><strong>Fiyat:</strong> @Model.Price.ToString("C")</p>
                    <p class="mb-1"><strong>Stok:</strong> @Model.StockQuantity</p>
                    <p class="mb-0"><strong>Durum:</strong> @(Model.IsActive ? "Aktif" : "Pasif")</p>
                </div>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger"><i class="fa-solid fa-trash me-1"></i> Evet, Sil</button>
                <a asp-action="Index" class="btn btn-secondary">İptal</a>
            </form>
        </div>
    </div>
</div>
