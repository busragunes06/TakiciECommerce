@model Web.Models.Product
@{
    ViewData["Title"] = "Ürün Düzenle";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2">Ürün Düzenle: @Model.Name</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="fa-solid fa-arrow-left me-1"></i> Listeye Dön
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <form asp-action="Edit" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CreatedAtUtc" />
                    <input type="hidden" asp-for="ImageUrl" />
                    
                    <div class="row mb-3">
                        <div class="col-md-8">
                            <label asp-for="Name" class="form-label fw-bold">Ürün Adı *</label>
                            <input asp-for="Name" class="form-control" required />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="CategoryId" class="form-label fw-bold">Kategori *</label>
                            <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories" required></select>
                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-bold">Açıklama</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-4">
                            <label asp-for="Price" class="form-label fw-bold">Fiyat (₺) *</label>
                            <input asp-for="Price" type="number" step="0.01" class="form-control" required />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="StockQuantity" class="form-label fw-bold">Stok Miktarı *</label>
                            <input asp-for="StockQuantity" type="number" class="form-control" required />
                            <span asp-validation-for="StockQuantity" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 d-flex align-items-end mb-2">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="IsActive">
                                <label class="form-check-label fw-bold" asp-for="IsActive">Satışa Açık</label>
                            </div>
                        </div>
                    </div>
                    
                    <div class="row mb-4">
                        <div class="col-md-8">
                            <label class="form-label fw-bold">Yeni Görsel Yükle</label>
                            <input type="file" name="imageFile" class="form-control" accept="image/*" />
                            <div class="form-text">Mevcut görseli değiştirmek istemiyorsanız boş bırakın.</div>
                        </div>
                        <div class="col-md-4 text-center">
                            @if(!string.IsNullOrEmpty(Model.ImageUrl)) {
                                <img src="@Model.ImageUrl" class="img-thumbnail" style="max-height: 100px;" alt="Mevcut Görsel" />
                                <div class="small text-muted mt-1">Mevcut Görsel</div>
                            }
                        </div>
                    </div>

                    <div class="d-grid gap-2 text-end">
                        <button type="submit" class="btn btn-primary btn-lg"><i class="fa-solid fa-save me-1"></i> Güncelle</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
