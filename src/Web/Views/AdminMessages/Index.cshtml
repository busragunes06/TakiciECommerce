@model IEnumerable<Web.Models.ContactMessage>
@{
    ViewData["Title"] = "Gelen Mesajlar";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2">Gelen Mesajlar</h1>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Tarih</th>
                        <th>Kimden</th>
                        <th>Konu</th>
                        <th>Durum</th>
                        <th class="text-end pe-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var msg in Model)
                    {
                        <tr class="@(!msg.IsRead ? "fw-bold" : "")">
                            <td class="ps-4">
                                @msg.CreatedAtUtc.AddHours(3).ToString("dd.MM.yyyy HH:mm")
                            </td>
                            <td>
                                <div>@msg.Name</div>
                                <div class="small text-muted fw-normal">@msg.Email</div>
                            </td>
                            <td>
                                @(msg.Subject.Length > 40 ? msg.Subject.Substring(0, 40) + "..." : msg.Subject)
                            </td>
                            <td>
                                @if (msg.IsRead)
                                {
                                    <span class="badge bg-secondary">Okundu</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary">Yeni</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <a asp-controller="AdminMessages" asp-action="Details" asp-route-id="@msg.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                    Oku
                                </a>
                                <form asp-action="Delete" asp-route-id="@msg.Id" method="post" class="d-inline" onsubmit="return confirm('Bu mesajı silmek istediğinize emin misiniz?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                        Sil
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="fa-regular fa-envelope-open fs-1 mb-3"></i><br />
                                Hiç mesaj bulunmuyor.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
