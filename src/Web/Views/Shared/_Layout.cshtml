<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Takıcı</title>
    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Web.styles.css" asp-append-version="true" />
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="~/images/crown-logo.svg" />
</head>
<body class="fade-in">
    <header>
        <nav class="navbar navbar-expand-lg py-3">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center brand-font" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/crown-logo.svg" alt="Takıcı Kraliçe Tacı" style="height: 32px; margin-right: 8px;" />
                    Takıcı
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Gezinmeyi aç/kapat">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link px-3" asp-area="" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" asp-controller="Products" asp-action="Index">Tüm Ürünler</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" asp-controller="Categories" asp-action="Index">Kategoriler</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" asp-area="" asp-controller="Home" asp-action="Contact">İletişim</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav d-flex align-items-center">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item me-3">
                                <a class="nav-link text-dark position-relative" asp-controller="Cart" asp-action="Index">
                                    <i class="fa-solid fa-basket-shopping fs-5"></i>
                                    <!-- Dinamik sepet sayısı buraya eklenebilir -->
                                </a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fa-regular fa-circle-user fs-5 me-1"></i> @User.Identity?.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="navbarDropdown">
                                    <li><a class="dropdown-item" asp-controller="Orders" asp-action="Index">Siparişlerim</a></li>
                                    <li><a class="dropdown-item" asp-controller="Profile" asp-action="Index">Hesabım</a></li>
                                    @if(User.IsInRole("Admin"))
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Index">Yönetici Paneli</a></li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="dropdown-item p-0">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-link dropdown-item text-danger text-start">Çıkış Yap</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item me-2">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">Giriş Yap</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm px-4 rounded-pill" asp-controller="Account" asp-action="Register">Kayıt Ol</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container flex-grow-1 my-5 slide-up">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer>
        <div class="container">
            <div class="row gy-4">
                <div class="col-md-4">
                    <h3 class="brand-font fs-3 text-primary mb-3 d-flex align-items-center">
                        <img src="~/images/crown-logo.svg" alt="Takıcı Logo" style="height: 28px; margin-right: 10px;" /> Takıcı
                    </h3>
                    <p class="text-muted pe-md-5">Zarafetinizi tamamlayacak en özel tasarım takılar ile parlayın. Kendinize ve sevdiklerinize anlamlı bir hediye seçin.</p>
                </div>
                <div class="col-md-2 offset-md-1">
                    <h4 class="footer-heading">Kategoriler</h4>
                    <ul class="footer-links">
                        <li><a href="/urunler?category=kolye">Kolyeler</a></li>
                        <li><a href="/urunler?category=yuzuk">Yüzükler</a></li>
                        <li><a href="/urunler?category=kupe">Küpeler</a></li>
                        <li><a href="/urunler?category=bileklik">Bileklikler</a></li>
                    </ul>
                </div>
                <div class="col-md-2">
                    <h4 class="footer-heading">Kurumsal</h4>
                    <ul class="footer-links">
                        <li><a href="#">Hakkımızda</a></li>
                        <li><a asp-controller="Home" asp-action="Contact">İletişim</a></li>
                        <li><a asp-controller="Home" asp-action="Privacy">Gizlilik Politikası</a></li>
                        <li><a href="#">Mesafeli Satış Sözleşmesi</a></li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h4 class="footer-heading">Bizi Takip Edin</h4>
                    <div class="d-flex gap-3">
                        <a href="#" class="text-muted fs-4"><i class="fa-brands fa-instagram"></i></a>
                        <a href="#" class="text-muted fs-4"><i class="fa-brands fa-pinterest"></i></a>
                        <a href="#" class="text-muted fs-4"><i class="fa-brands fa-tiktok"></i></a>
                    </div>
                </div>
            </div>
            <hr class="my-4 text-muted">
            <div class="text-center text-muted small">
                &copy; @DateTime.Now.Year - Takıcı E-Ticaret A.Ş. Tüm Hakları Saklıdır.
            </div>
        </div>
    </footer>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
