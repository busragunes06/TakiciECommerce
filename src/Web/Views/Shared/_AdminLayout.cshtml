@inject Web.Data.AppDbContext DbContext
@{
    var unreadMessageCount = DbContext.ContactMessages.Count(m => !m.IsRead);
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Yonetim Paneli - Takici</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <style>
        :root {
            --color-primary: #e87b96;
            --color-primary-hover: #d25a7a;
            --color-secondary: #ffe6ea;
            --color-accent: #ffb6c1;
            --color-bg: #fff5f7;
            --color-surface: #ffffff;
            --color-text-main: #4a2c31;
            --color-text-muted: #8c6b71;
            --color-border: #f8dbdf;
            
            --admin-sidebar-bg: #ffe6ea;
            --admin-sidebar-text: #4a2c31;
            --admin-sidebar-hover: rgba(232, 123, 150, 0.15);
        }

        body {
            background-color: var(--color-bg);
            font-family: 'Inter', sans-serif;
            color: var(--color-text-main);
        }

        h1, h2, h3, h4, h5, h6 {
            font-family: 'Playfair Display', serif;
            color: var(--color-text-main);
        }

        #wrapper {
            display: flex;
            width: 100%;
            min-height: 100vh;
            overflow: hidden;
        }

        #sidebar {
            width: 250px;
            background: linear-gradient(180deg, #ffe6ea 0%, #ffd6df 100%);
            color: var(--admin-sidebar-text);
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            border-right: 1px solid var(--color-border);
            box-shadow: 2px 0 10px rgba(232, 123, 150, 0.05);
        }

        #sidebar .sidebar-heading {
            padding: 1.5rem 1rem;
            font-size: 1.4rem;
            font-family: 'Playfair Display', serif;
            font-weight: 700;
            border-bottom: 1px solid var(--color-border);
            text-align: center;
            letter-spacing: 1px;
            color: var(--color-primary);
        }

        .list-group-item {
            background: transparent;
            color: var(--admin-sidebar-text);
            border: none;
            padding: 1rem 1.5rem;
            font-weight: 500;
            transition: all 0.3s ease;
            position: relative;
        }

        .list-group-item i {
            color: var(--color-primary);
            transition: all 0.3s ease;
        }

        .list-group-item:hover,
        .list-group-item.active {
            color: var(--color-primary-hover);
            background: var(--admin-sidebar-hover);
            border-right: 4px solid var(--color-primary);
            text-decoration: none;
        }

        .list-group-item.active i {
            color: var(--color-primary-hover);
        }

        #page-content-wrapper {
            flex-grow: 1;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
        }

        .admin-navbar {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--color-border);
            min-height: 65px;
            display: flex;
            align-items: center;
            padding: 0 2rem;
            justify-content: flex-end;
            box-shadow: 0 2px 8px rgba(232, 123, 150, 0.08);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .admin-content {
            padding: 2.5rem;
            flex-grow: 1;
        }
        
        .btn-primary-custom {
            background-color: var(--color-primary);
            border-color: var(--color-primary);
            color: white;
        }
        .btn-primary-custom:hover {
            background-color: var(--color-primary-hover);
            border-color: var(--color-primary-hover);
            color: white;
        }
        
        .btn-outline-custom {
            border-color: var(--color-primary);
            color: var(--color-primary);
        }
        .btn-outline-custom:hover {
            background-color: var(--color-primary);
            color: white;
        }

        /* Card and Table Overrides for Admin Theme */
        .card {
            border-radius: 12px;
            border-color: var(--color-border) !important;
            box-shadow: 0 4px 12px rgba(232, 123, 150, 0.08) !important;
            background-color: var(--color-surface);
        }
        
        .table {
            color: var(--color-text-main);
        }
        .table-dark {
            background-color: var(--color-primary);
            color: white;
            border-color: var(--color-primary-hover);
        }
        .table-dark th {
            background-color: var(--color-primary);
            border-color: var(--color-border);
            font-weight: 500;
        }
        .table-striped>tbody>tr:nth-of-type(odd)>* {
            background-color: var(--color-bg);
            color: var(--color-text-main);
        }
        .badge.bg-warning { background-color: #f6c23e !important; color: #fff !important; }
        .badge.bg-info { background-color: #36b9cc !important; color: #fff !important; }
        .badge.bg-success { background-color: #1cc88a !important; color: #fff !important; }
        .badge.bg-danger { background-color: #e74a3b !important; color: #fff !important; }
    </style>
</head>
<body>
    <div id="wrapper">
        <div id="sidebar">
            <div class="sidebar-heading">
                <i class="fa-solid fa-crown me-2"></i>Takıcı Admin
            </div>
            <div class="list-group list-group-flush mt-3 flex-grow-1">
                <a asp-controller="Admin" asp-action="Index" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                    <i class="fa-solid fa-gauge me-3"></i> Dashboard
                </a>
                <a asp-controller="AdminProducts" asp-action="Index" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Controller"]?.ToString() == "AdminProducts" ? "active" : "")">
                    <i class="fa-solid fa-box-open me-3"></i> Ürünler
                </a>
                <a asp-controller="AdminCategories" asp-action="Index" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Controller"]?.ToString() == "AdminCategories" ? "active" : "")">
                    <i class="fa-solid fa-tags me-3"></i> Kategoriler
                </a>
                <a asp-controller="AdminOrders" asp-action="Index" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Controller"]?.ToString() == "AdminOrders" ? "active" : "")">
                    <i class="fa-solid fa-cart-flatbed me-3"></i> Siparişler
                </a>
                <a asp-controller="AdminUsers" asp-action="Index" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Controller"]?.ToString() == "AdminUsers" ? "active" : "")">
                    <i class="fa-solid fa-users me-3"></i> Müşteriler
                </a>
                <a asp-controller="AdminMessages" asp-action="Index" class="list-group-item list-group-item-action @(ViewContext.RouteData.Values["Controller"]?.ToString() == "AdminMessages" ? "active" : "")">
                    <i class="fa-solid fa-envelope me-3"></i> Mesajlar
                    @if (unreadMessageCount > 0)
                    {
                        <span class="badge bg-danger rounded-pill position-absolute end-0 me-3 mt-1">@unreadMessageCount</span>
                    }
                </a>
            </div>
            <div class="p-4">
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-custom w-100 btn-sm rounded-pill fw-bold">
                    <i class="fa-solid fa-globe me-2"></i> Siteye Dön
                </a>
            </div>
        </div>

        <div id="page-content-wrapper">
            <nav class="admin-navbar">
                <div class="d-flex align-items-center">
                    <a asp-controller="AdminMessages" asp-action="Index" class="text-muted position-relative me-4" style="text-decoration:none;">
                        <i class="fa-solid fa-bell fs-5"></i>
                        @if (unreadMessageCount > 0)
                        {
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:0.65rem;">
                                @unreadMessageCount
                            </span>
                        }
                    </a>
                    <span class="me-4 text-muted fw-medium">Hoşgeldiniz, <span class="text-primary fw-bold">@User.Identity?.Name</span></span>
                    <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-primary-custom rounded-pill px-3">
                            <i class="fa-solid fa-right-from-bracket me-2"></i>Çıkış
                        </button>
                    </form>
                </div>
            </nav>

            <div class="admin-content">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0" style="background-color:#d1e7dd; color:#0f5132;" role="alert">
                        <i class="fa-solid fa-circle-check me-2"></i> @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
