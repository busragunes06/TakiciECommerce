@model Web.ViewModels.Catalog.ProductDetailsVm

@{
    ViewData["Title"] = Model.Name;
}

<div class="container py-4 fade-in">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-muted text-decoration-none">Ana Sayfa</a></li>
            <li class="breadcrumb-item"><a asp-controller="Products" asp-action="Index" class="text-muted text-decoration-none">Ürünler</a></li>
            
            <li class="breadcrumb-item">
                <a asp-controller="Products" asp-action="Index" asp-route-categoryId="@Model.CategoryId" class="text-muted text-decoration-none">@Model.CategoryName</a>
            </li>
            
            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="row align-items-center g-5 slide-up">
        <div class="col-md-6 col-lg-5">
            <div class="position-relative overflow-hidden rounded-4 shadow-sm bg-white" style="aspect-ratio: 4/5;">
                @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" class="w-100 h-100 object-fit-cover" alt="@Model.Name" />
                }
                else
                {
                    <div class="w-100 h-100 d-flex align-items-center justify-content-center text-muted bg-light">
                        <i class="fa-solid fa-gem fs-1 opacity-25"></i>
                    </div>
                }
            </div>
        </div>

        <div class="col-md-6 col-lg-7">
            <div class="ps-md-4">
                <span class="badge bg-secondary opacity-75 fw-normal text-uppercase letter-spacing-1 mb-2">@Model.CategoryName</span>
                <h1 class="brand-font display-5 mb-3 text-dark">@Model.Name</h1>
                
                <div class="fs-2 text-primary fw-semibold mb-4">@Model.Price.ToString("C")</div>
                
                <p class="text-muted mb-4 fs-5" style="line-height: 1.8;">
                    @if (!string.IsNullOrWhiteSpace(Model.Description))
                    {
                        @Model.Description
                    }
                    else
                    {
                        <span class="fst-italic opacity-75">Bu zarif tasarımımızın detayı belirtilmemiştir.</span>
                    }
                </p>

                <div class="mb-4 pb-4 border-bottom">
                    <div class="d-flex align-items-center mb-3">
                        <div class="me-3">
                            <i class="fa-solid fa-circle-check @(Model.StockQuantity > 0 ? "text-success" : "text-muted") fs-5"></i>
                        </div>
                        <span class="fw-medium @(Model.StockQuantity > 0 ? "text-dark" : "text-danger")">
                            @(Model.StockQuantity > 0 ? $"Stokta ({Model.StockQuantity} adet)" : "Geçici Süreliğine Tükendi")
                        </span>
                    </div>
                    
                    <div class="d-flex align-items-center text-muted small">
                        <i class="fa-solid fa-shield-halved me-2"></i> Güvenli Alışveriş ve Hızlı Kargo
                    </div>
                </div>

                @if (Model.StockQuantity > 0)
                {
                    <form asp-controller="Cart" asp-action="Add" method="post" class="d-flex flex-wrap gap-3 align-items-center">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="productId" value="@Model.Id" />
                        
                        <div class="input-group" style="width: 140px;">
                            <span class="input-group-text bg-white border-end-0">Adet</span>
                            <input type="number" name="quantity" value="1" min="1" max="@Model.StockQuantity" class="form-control border-start-0 text-center" />
                        </div>
                        
                        <button class="btn btn-primary btn-lg rounded-pill px-5 flex-grow-1" type="submit">
                            <i class="fa-solid fa-basket-shopping me-2"></i> Sepete Ekle
                        </button>
                    </form>
                }
                else
                {
                    <button class="btn btn-outline-secondary btn-lg rounded-pill w-100" disabled>Gelince Haber Ver</button>
                    <div class="text-muted small mt-2 text-center">Şu an stoklarımızda bulunmuyor, alternatiflere göz atabilirsiniz.</div>
                }
            </div>
        </div>
    </div>
</div>