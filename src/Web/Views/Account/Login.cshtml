@model Web.ViewModels.Account.LoginViewModel

@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="row justify-content-center align-items-center fade-in py-5" style="min-height: 60vh;">
    <div class="col-md-5 col-lg-4">
        <div class="glass-box p-5 text-center">
            
            <i class="fa-regular fa-user text-primary fs-1 mb-3"></i>
            <h2 class="brand-font mb-4">Tekrar Hoşgeldiniz</h2>
            <p class="text-muted small mb-4">Işıltılı dünyaya geri dönmek için giriş yapın.</p>

            <form asp-action="Login" method="post" class="text-start">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                <input type="hidden" asp-for="ReturnUrl" />

                <div class="mb-3">
                    <label asp-for="Email" class="form-label text-muted small text-uppercase letter-spacing-1">E-Posta Adresi</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-muted"><i class="fa-regular fa-envelope"></i></span>
                        <input asp-for="Email" class="form-control border-start-0 ps-0" autocomplete="email" placeholder="ornek@mail.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="mb-4">
                    <div class="d-flex justify-content-between">
                        <label asp-for="Password" class="form-label text-muted small text-uppercase letter-spacing-1">Şifre</label>
                        <a href="#" class="text-decoration-none small text-muted">Şifremi Unuttum</a>
                    </div>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 text-muted"><i class="fa-solid fa-lock text-muted" style="font-size: 0.9em;"></i></span>
                        <input asp-for="Password" type="password" class="form-control border-start-0 ps-0" autocomplete="current-password" placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                </div>

                <div class="form-check mb-4">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label text-muted small">Beni Hatırla</label>
                </div>

                <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-medium mb-4">Giriş Yap</button>
            </form>

            <div class="text-muted small">
                Hesabınız yok mu?
                <a asp-controller="Account" asp-action="Register" class="text-primary fw-medium text-decoration-none">Hemen Kayıt Ol</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
